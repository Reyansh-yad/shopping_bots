# Root / Frontend environment variables
# Copy this file to .env and fill in your values
# Never commit .env to version control

# ── Frontend → Backend URL (used by Vite and api.js) ──────────────────────
# In development the Vite proxy rewrites /auth, /search, /profile automatically.
# Set this to your production backend URL when deploying.
VITE_API_URL=http://localhost:8000
